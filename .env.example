# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=axelo
POSTGRES_PASSWORD=axelo
POSTGRES_DB=axelo
DATABASE_URL=postgresql://axelo:axelo@db:5432/axelo

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED: Change this to a random 32+ char string in production
SECRET_KEY=super-secret-key-change-me-in-production

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development           # development | production
ALLOWED_ORIGINS=http://localhost:4173,http://localhost:5173

# ── File Uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=/uploads               # mapped to the 'uploads' Docker volume

# ── Phase 2: GitHub Integration ───────────────────────────────────────────────
# Set these when connecting a GitHub repo to a project
# GITHUB_CLIENT_ID=your_github_app_client_id
# GITHUB_CLIENT_SECRET=your_github_app_client_secret

# Phase 3 — 2FA / OAuth / Webhooks
# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Must match the frontend origin (used for OAuth redirect_uri)
FRONTEND_URL=http://localhost:4173

# Phase 5 — Redis / Email Notifications Queue
REDIS_URL=redis://localhost:6379/0
EMAIL_NOTIFICATIONS_ENABLED=true

# Phase 4 — AI Features (get key at console.anthropic.com)
ANTHROPIC_API_KEY=
AI_ENABLED=true

# ── Email Verification ──────────────────────────────────────────────────────
EMAIL_VERIFICATION_ENABLED=true   # set false in dev to skip verification entirely
SMTP_HOST=smtp.gmail.com           # or smtp.sendgrid.net, smtp.mailgun.org, etc.
SMTP_PORT=587
SMTP_USERNAME=your@gmail.com
SMTP_PASSWORD=your-app-password    # Gmail: generate an App Password, not your account password
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=Axelo
SMTP_TLS=true

# ── CAPTCHA (Cloudflare Turnstile) ──────────────────────────────────────────
# Get keys free at: https://dash.cloudflare.com → Turnstile
CAPTCHA_ENABLED=true
CAPTCHA_PROVIDER=turnstile          # "turnstile" or "hcaptcha"
CAPTCHA_SITE_KEY=                   # public key — shown to users
CAPTCHA_SECRET_KEY=                 # secret key — backend only, never expose

# For local dev with no CAPTCHA keys: set CAPTCHA_ENABLED=false

# ── Content-Security-Policy ─────────────────────────────────────────────────
# Optional: send CSP violation reports to a collector (https://report-uri.com
# offers a free tier). Leave empty to omit the report-uri directive.
CSP_REPORT_URI=
